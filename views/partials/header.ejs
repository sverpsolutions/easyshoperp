<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
<style>
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }
.pulse-badge { animation: pulse 1.5s infinite; }
</style>
</head>
<body>
<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark-custom px-3 py-2">
    <a class="navbar-brand fw-bold" href="#">
        <i class="bi bi-qr-code-scan me-2"></i>
        <span class="fw-bold">BARCODE</span> MES
        <% if(typeof license !== 'undefined' && license){ %>
          <% if(license.daysLeft <= 14){ %>
            <span class="badge bg-danger ms-2 pulse-badge" style="font-size:0.6rem;">
              <i class="bi bi-clock me-1"></i>EXPIRES IN <%= license.daysLeft %>d
            </span>
          <% } else { %>
            <span class="badge ms-2" style="background:rgba(255,255,255,0.15);font-size:0.6rem;color:rgba(255,255,255,0.7);">
              <i class="bi bi-shield-check me-1"></i>LICENSED
            </span>
          <% } %>
        <% } %>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
        <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navMenu">
        <ul class="navbar-nav ms-auto align-items-center">
            <% if (user) { %>
                <% if (user.role === 'Owner') { %>
                    <li class="nav-item"><a class="nav-link" href="/owner/dashboard"><i class="bi bi-grid-3x3-gap me-1"></i>Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/owner/jobs"><i class="bi bi-list-check me-1"></i>Jobs</a></li>
                    <li class="nav-item"><a class="nav-link" href="/owner/bills"><i class="bi bi-receipt me-1"></i>Bills</a></li>
                    <li class="nav-item dropdown">
                      <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="bi bi-people me-1"></i>Masters</a>
                      <ul class="dropdown-menu shadow">
                        <li><a class="dropdown-item" href="/owner/customers"><i class="bi bi-building me-2 text-info"></i>Customer Master</a></li>
                        <li><a class="dropdown-item" href="/owner/employees"><i class="bi bi-people me-2 text-purple"></i>Employee Master</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/owner/advances"><i class="bi bi-cash-stack me-2 text-warning"></i>Advance Requests</a></li>
                        <li><a class="dropdown-item" href="/attendance"><i class="bi bi-calendar-check me-2 text-info"></i>Attendance</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/owner/customers/order-requests"><i class="bi bi-bag-fill me-2" style="color:#f59e0b;"></i>Order Requests <span class="badge bg-danger ms-1" id="orderReqBadge" style="display:none;"></span></a></li>
                      </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="/owner/reports"><i class="bi bi-bar-chart me-1"></i>Reports</a></li>
                    <li class="nav-item"><a class="nav-link" href="/owner/settings"><i class="bi bi-gear me-1"></i>Settings</a></li>
                <% } else if (user.role === 'Admin') { %>
                    <li class="nav-item"><a class="nav-link" href="/admin/dashboard"><i class="bi bi-gear me-1"></i>Admin</a></li>
                    <li class="nav-item"><a class="nav-link" href="/owner/dashboard"><i class="bi bi-grid-3x3-gap me-1"></i>Factory View</a></li>
                    <li class="nav-item"><a class="nav-link" href="/owner/bills"><i class="bi bi-receipt me-1"></i>Bills</a></li>
                    <li class="nav-item"><a class="nav-link" href="/advances/admin-view"><i class="bi bi-cash-stack me-1"></i>Give Advance</a></li>
                <% } else { %>
                    <li class="nav-item"><a class="nav-link" href="/operator/dashboard"><i class="bi bi-person-workspace me-1"></i>My Dashboard</a></li>
                <% } %>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle fw-bold" href="#" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-1"></i><%= user.name %>
                        <span class="badge bg-secondary ms-1"><%= user.role %></span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow">
                        <li><a class="dropdown-item" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                    </ul>
                </li>
            <% } %>
        </ul>
    </div>
</nav>

<!-- ── LICENSE WARNING BANNER ── -->
<% if(typeof licenseWarning !== 'undefined' && licenseWarning){ %>
<div class="text-center py-2 px-3 fw-bold" style="background:linear-gradient(90deg,#dc3545,#fd7e14);color:white;font-size:0.85rem;">
  <i class="bi bi-exclamation-triangle-fill me-2"></i><%= licenseWarning %>
  <a href="/register" class="btn btn-sm btn-light fw-bold ms-3 py-0 px-2" style="font-size:0.75rem;">Renew Now</a>
</div>
<% } %>

<!-- ── TOAST NOTIFICATION SYSTEM ── -->
<div class="toast-container position-fixed top-0 start-50 translate-middle-x p-3" style="z-index:9999;top:70px!important;">
  <% if (success && success.length > 0) { %>
    <div id="toastSuccess" class="toast align-items-center border-0 show" role="alert"
         style="background:#198754;color:white;min-width:320px;max-width:480px;box-shadow:0 8px 32px rgba(0,0,0,0.25);border-radius:12px;">
      <div class="d-flex">
        <div class="toast-body fw-bold d-flex align-items-center gap-2" style="font-size:1rem;">
          <i class="bi bi-check-circle-fill fs-5 flex-shrink-0"></i>
          <span><%= success %></span>
        </div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
      </div>
      <!-- progress bar -->
      <div style="height:4px;background:rgba(255,255,255,0.3);border-radius:0 0 12px 12px;overflow:hidden;">
        <div id="successBar" style="height:100%;background:white;width:100%;transition:width 4s linear;"></div>
      </div>
    </div>
  <% } %>
  <% if (error && error.length > 0) { %>
    <div id="toastError" class="toast align-items-center border-0 show" role="alert"
         style="background:#dc3545;color:white;min-width:320px;max-width:480px;box-shadow:0 8px 32px rgba(0,0,0,0.25);border-radius:12px;">
      <div class="d-flex">
        <div class="toast-body fw-bold d-flex align-items-center gap-2" style="font-size:1rem;">
          <i class="bi bi-exclamation-triangle-fill fs-5 flex-shrink-0"></i>
          <span><%= error %></span>
        </div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
      </div>
      <div style="height:4px;background:rgba(255,255,255,0.3);border-radius:0 0 12px 12px;overflow:hidden;">
        <div id="errorBar" style="height:100%;background:white;width:100%;transition:width 6s linear;"></div>
      </div>
    </div>
  <% } %>
</div>
<script>
// Auto-dismiss toasts + animate progress bar
document.addEventListener('DOMContentLoaded', function(){
  // Success toast — 4 seconds
  const ts = document.getElementById('toastSuccess');
  const sb = document.getElementById('successBar');
  if(ts && sb){
    requestAnimationFrame(()=>{ requestAnimationFrame(()=>{ sb.style.width='0%'; }); });
    setTimeout(()=>{ ts.classList.remove('show'); ts.style.opacity='0'; ts.style.transition='opacity 0.4s'; }, 4000);
  }
  // Error toast — 6 seconds (errors need more reading time)
  const te = document.getElementById('toastError');
  const eb = document.getElementById('errorBar');
  if(te && eb){
    requestAnimationFrame(()=>{ requestAnimationFrame(()=>{ eb.style.width='0%'; }); });
    setTimeout(()=>{ te.classList.remove('show'); te.style.opacity='0'; te.style.transition='opacity 0.4s'; }, 6000);
  }
});
</script>
