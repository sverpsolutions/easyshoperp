<%- include('../partials/header') %>
<div class="container-fluid p-3">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-cash-stack me-2" style="color:#f59e0b;"></i>CASH DISBURSEMENT — ADVANCES</h5>
    <span class="badge bg-warning text-dark fs-6"><%= advances.filter(a=>a.Status==='Approved').length %> Ready to Pay</span>
  </div>

  <% const toGive = advances.filter(a=>a.Status==='Approved'); %>
  <% if(toGive.length){ %>
  <div class="chart-card mb-3" style="border-left:4px solid #f59e0b;">
    <h6 class="fw-bold text-warning mb-3"><i class="bi bi-exclamation-circle me-1"></i>GIVE CASH NOW (<%= toGive.length %>)</h6>
    <div class="row g-3">
      <% toGive.forEach(a=>{ %>
      <div class="col-md-6 col-lg-4">
        <div class="p-3 border rounded" style="background:#fffbf0;">
          <div class="d-flex justify-content-between mb-2">
            <div><strong><%= a.Employee_Name %></strong><br><small class="text-muted"><%= a.Role %></small></div>
            <div class="text-end"><div class="fw-bold fs-5 text-warning">₹<%= parseFloat(a.Amount_Approved).toLocaleString('en-IN') %></div>
              <small class="text-muted">Approved by <%= a.Approved_By_Name %></small></div>
          </div>
          <% if(a.Notes){ %><div class="small text-muted mb-2"><i class="bi bi-sticky me-1"></i><%= a.Notes %></div><% } %>
          <button class="btn btn-warning w-100 fw-bold" data-bs-toggle="modal" data-bs-target="#payModal<%= a.Advance_ID %>"><i class="bi bi-cash me-1"></i>Give Cash</button>
        </div>
      </div>
      <div class="modal fade" id="payModal<%= a.Advance_ID %>" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header" style="background:#f59e0b;"><h5 class="modal-title fw-bold">Give Cash — <%= a.Employee_Name %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form method="POST" action="/advances/<%= a.Advance_ID %>/pay">
              <div class="modal-body">
                <div class="alert alert-warning"><strong>Approved: ₹<%= parseFloat(a.Amount_Approved).toLocaleString('en-IN') %></strong></div>
                <label class="form-label fw-bold small">ACTUAL AMOUNT GIVEN (₹)</label>
                <input type="number" name="amount_paid" class="form-control form-control-lg" value="<%= a.Amount_Approved %>" required>
                <label class="form-label fw-bold small mt-3">PAYMENT MODE</label>
                <select name="payment_mode" class="form-select"><option>Cash</option><option>Bank Transfer</option><option>UPI</option></select>
                <label class="form-label fw-bold small mt-3">NOTES</label>
                <input type="text" name="notes" class="form-control" placeholder="Any remarks">
              </div>
              <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-warning fw-bold">💰 Given</button></div>
            </form>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
  <% } else { %>
  <div class="chart-card text-center py-5 text-muted"><i class="bi bi-check-circle fs-1 text-success"></i><div class="mt-2">No pending cash disbursements</div></div>
  <% } %>

  <!-- History -->
  <div class="chart-card">
    <h6 class="fw-bold mb-3"><i class="bi bi-clock-history me-1"></i>Recent Payments</h6>
    <div class="table-responsive">
      <table class="table table-sm table-hover">
        <thead style="background:#f8f9fa;"><tr><th>Employee</th><th>Date</th><th>Amount</th><th>Mode</th><th>Notes</th></tr></thead>
        <tbody>
          <% advances.filter(a=>a.Status==='Paid').slice(0,20).forEach(a=>{ %>
          <tr>
            <td class="fw-bold"><%= a.Employee_Name %></td>
            <td class="small"><%= a.Paid_Date?new Date(a.Paid_Date).toLocaleDateString('en-IN'):'—' %></td>
            <td class="text-danger fw-bold">₹<%= parseFloat(a.Amount_Paid||0).toLocaleString('en-IN') %></td>
            <td class="small"><%= a.Payment_Mode||'Cash' %></td>
            <td class="small text-muted"><%= a.Notes||'—' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
