<%- include('../partials/header') %>
<div class="container-fluid p-3">
    <h5 class="fw-bold mb-3" style="color:#1a1a2e;"><i class="bi bi-gear-fill me-2 text-warning"></i>ADMIN PANEL</h5>

    <!-- Tabs -->
    <ul class="nav nav-tabs nav-tabs-dark mb-3" id="adminTabs">
        <li class="nav-item">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#empTab">
                <i class="bi bi-people me-1"></i>Employees (<%= employees.length %>)
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#machineTab">
                <i class="bi bi-cpu me-1"></i>Machines (<%= machines.length %>)
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <!-- EMPLOYEES TAB -->
        <div class="tab-pane fade show active" id="empTab">
            <div class="d-flex justify-content-end mb-2">
                <button class="btn btn-warning btn-sm fw-bold" data-bs-toggle="modal" data-bs-target="#addEmpModal">
                    <i class="bi bi-person-plus me-1"></i>Add Employee
                </button>
            </div>
            <div class="chart-card">
                <div class="table-responsive">
                    <table class="table table-dark table-hover table-sm mb-0">
                        <thead><tr class="text-secondary small">
                            <th>ID</th><th>NAME</th><th>ROLE</th><th>USERNAME</th><th>MOBILE</th><th>STATUS</th><th>LAST LOGIN</th><th>ACTION</th>
                        </tr></thead>
                        <tbody>
                            <% employees.forEach(e => { %>
                            <tr>
                                <td class="text-muted">#<%= e.Employee_ID %></td>
                                <td class="fw-bold"><%= e.Name %></td>
                                <td><span class="badge <%= e.Role==='Owner'?'bg-warning text-dark':e.Role==='Admin'?'bg-info text-dark':'bg-secondary' %>"><%= e.Role %></span></td>
                                <td class="text-muted small"><%= e.Username %></td>
                                <td class="text-muted small"><%= e.Mobile || '—' %></td>
                                <td><span class="badge <%= e.Is_Active?'bg-success':'bg-danger' %>"><%= e.Is_Active?'Active':'Inactive' %></span></td>
                                <td class="text-muted small"><%= e.Last_Login ? new Date(e.Last_Login).toLocaleString() : 'Never' %></td>
                                <td>
                                    <form action="/admin/employee/<%= e.Employee_ID %>/toggle" method="POST" style="display:inline">
                                        <button type="submit" class="btn btn-xs btn-outline-<%= e.Is_Active?'danger':'success' %>">
                                            <%= e.Is_Active?'Deactivate':'Activate' %>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- MACHINES TAB -->
        <div class="tab-pane fade" id="machineTab">
            <div class="chart-card">
                <div class="table-responsive">
                    <table class="table table-dark table-hover table-sm mb-0">
                        <thead><tr class="text-secondary small">
                            <th>ID</th><th>NAME</th><th>TYPE</th><th>LOCATION</th><th>STATUS</th><th>CHANGE STATUS</th>
                        </tr></thead>
                        <tbody>
                            <% machines.forEach(m => { %>
                            <tr>
                                <td class="text-muted">#<%= m.Machine_ID %></td>
                                <td class="fw-bold text-primary"><%= m.Machine_Name %></td>
                                <td><span class="badge <%= m.Machine_Type==='Auto'?'badge-auto':'badge-manual' %>"><%= m.Machine_Type %></span></td>
                                <td class="text-muted small"><%= m.Location || '—' %></td>
                                <td><span class="badge bg-<%= m.Status==='Running'?'success':m.Status==='Idle'?'warning text-dark':m.Status==='Maintenance'?'info':'danger' %>"><%= m.Status %></span></td>
                                <td>
                                    <form action="/admin/machine/<%= m.Machine_ID %>/status" method="POST" style="display:inline">
                                        <select name="status" class="form-select form-select-sm bg-dark border-secondary text-white d-inline w-auto" onchange="this.form.submit()">
                                            <option value="">Change...</option>
                                            <option value="Idle">Idle</option>
                                            <option value="Maintenance">Maintenance</option>
                                            <option value="Stopped">Stopped</option>
                                        </select>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ADD EMPLOYEE MODAL -->
<div class="modal fade" id="addEmpModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-dark">
            <div class="modal-header">
                <h5 class="modal-title text-white"><i class="bi bi-person-plus me-2 text-warning"></i>Add Employee</h5>
                <button type="button" class="btn-close btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/admin/employee/create" method="POST">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label text-secondary small">FULL NAME</label>
                            <input type="text" name="name" class="form-control bg-dark border-secondary text-white" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">ROLE</label>
                            <select name="role" class="form-select bg-dark border-secondary text-white" required>
                                <option value="Operator">Operator</option>
                                <option value="Admin">Admin</option>
                                <option value="Owner">Owner</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">MOBILE</label>
                            <input type="text" name="mobile" class="form-control bg-dark border-secondary text-white">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">USERNAME</label>
                            <input type="text" name="username" class="form-control bg-dark border-secondary text-white" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">PASSWORD</label>
                            <input type="password" name="password" class="form-control bg-dark border-secondary text-white" required>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning fw-bold"><i class="bi bi-person-plus me-1"></i>CREATE</button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
