<%- include('../partials/header') %>
<div class="container-fluid p-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold mb-0" style="color:#1a1a2e;"><i class="bi bi-shield-check me-2 text-danger"></i>AUDIT LOG</h5>
        <a href="/admin/dashboard" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
    <div class="chart-card">
        <div class="table-responsive">
            <table class="table table-dark table-hover table-sm mb-0">
                <thead><tr class="text-secondary small">
                    <th>TIME</th><th>EMPLOYEE</th><th>ACTION</th><th>IP</th>
                </tr></thead>
                <tbody>
                    <% logs.forEach(l => { %>
                    <tr>
                        <td class="text-muted small"><%= new Date(l.Log_Time).toLocaleString() %></td>
                        <td class="small fw-bold"><%= l.Employee_Name || 'System' %></td>
                        <td class="text-info small"><%= l.Action %></td>
                        <td class="text-muted small"><%= l.IP_Address || '—' %></td>
                    </tr>
                    <% }) %>
                    <% if (!logs.length) { %>
                    <tr><td colspan="4" class="text-center text-muted py-4">No audit entries found</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<%- include('../partials/footer') %>
