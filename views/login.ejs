<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Barcode MES System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-page d-flex align-items-center justify-content-center min-vh-100">

<div class="login-container text-center">
    <div class="mb-4">
        <i class="bi bi-qr-code-scan" style="font-size:3rem; color:#1a73e8;"></i>
        <h2 class="fw-bold mt-2" style="color:#1a237e">BARCODE MES SYSTEM</h2>
        <p class="text-muted small">Industrial Manufacturing Execution System</p>
    </div>

    <% if (error && error.length > 0) { %>
        <div class="alert alert-danger py-2">
            <i class="bi bi-exclamation-triangle me-1"></i><%= error %>
        </div>
    <% } %>

    <form action="/login" method="POST" class="login-form">
        <div class="mb-3 text-start">
            <label class="form-label text-secondary small">USERNAME</label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-secondary">
                    <i class="bi bi-person"></i>
                </span>
                <input type="text" name="username" class="form-control bg-dark border-secondary text-white"
                       placeholder="Enter username" required autofocus>
            </div>
        </div>
        <div class="mb-4 text-start">
            <label class="form-label text-secondary small">PASSWORD</label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-secondary">
                    <i class="bi bi-lock"></i>
                </span>
                <input type="password" name="password" class="form-control bg-dark border-secondary text-white"
                       placeholder="Enter password" required>
            </div>
        </div>
        <button type="submit" class="btn btn-warning w-100 fw-bold py-2">
            <i class="bi bi-box-arrow-in-right me-2"></i>LOGIN
        </button>
    </form>

    <div class="mt-4 text-secondary small">
        <div class="d-flex gap-3 justify-content-center text-muted" style="font-size:0.75rem;">
            <span><i class="bi bi-shield-check text-success me-1"></i>Owner: owner / Admin@123</span>
            <span><i class="bi bi-person text-warning me-1"></i>Operator: rahul / Operator@123</span>
        </div>
    </div>

    <div class="mt-3 text-secondary" style="font-size:0.7rem;">
        &copy; 2024 Factory MES System &mdash; 15 Machines · 15 Operators
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
