<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Product Registration — Barcode MES</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <style>
    body { background: linear-gradient(135deg, #0f0c29, #302b63, #24243e); min-height: 100vh; display:flex; align-items:center; justify-content:center; font-family: 'Segoe UI', sans-serif; }
    .reg-card { background: white; border-radius: 20px; overflow: hidden; max-width: 520px; width: 100%; box-shadow: 0 30px 80px rgba(0,0,0,0.5); }
    .reg-header { background: linear-gradient(135deg, #1a1a2e, #16213e); padding: 40px 35px 30px; text-align: center; }
    .reg-logo { width: 70px; height: 70px; background: linear-gradient(135deg, #f59e0b, #ef4444); border-radius: 18px; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px; font-size: 2rem; color: white; }
    .reg-body { padding: 35px; }
    .key-input { font-family: 'Courier New', monospace; font-size: 1.1rem; letter-spacing: 3px; text-transform: uppercase; text-align: center; border: 2px solid #dee2e6; border-radius: 10px; padding: 14px; background: #f8f9fa; }
    .key-input:focus { border-color: #f59e0b; box-shadow: 0 0 0 3px rgba(245,158,11,0.2); background: white; }
    .btn-activate { background: linear-gradient(135deg, #f59e0b, #ef4444); border: none; border-radius: 10px; padding: 14px; font-size: 1.1rem; font-weight: 700; color: white; width: 100%; }
    .btn-activate:hover { opacity: 0.9; color: white; transform: translateY(-1px); box-shadow: 0 8px 20px rgba(245,158,11,0.4); }
    .machine-id { font-family: monospace; background: #f0f4ff; border: 1px dashed #6c63ff; border-radius: 8px; padding: 8px 14px; font-size: 0.85rem; letter-spacing: 2px; color: #4a47a3; }
    .feature-list .item { display: flex; align-items: center; gap: 8px; padding: 4px 0; font-size: 0.85rem; color: #6c757d; }
    .success-box { background: linear-gradient(135deg, #d4edda, #c3e6cb); border: 2px solid #28a745; border-radius: 14px; padding: 25px; text-align: center; }
  </style>
</head>
<body>
<div class="reg-card">

  <!-- Header -->
  <div class="reg-header">
    <div class="reg-logo"><i class="bi bi-qr-code-scan"></i></div>
    <h4 class="text-white fw-bold mb-1">Barcode Label MES</h4>
    <p class="text-white-50 mb-0 small">Manufacturing Execution System — v4.1</p>
    <div class="mt-3 px-3 py-2 rounded" style="background:rgba(255,255,255,0.08);">
      <div class="text-white-50 small mb-1">Your Machine ID</div>
      <div class="machine-id"><%= machineId %></div>
      <div class="text-white-50 mt-1" style="font-size:0.7rem;">Share this with your vendor when purchasing a license</div>
    </div>
  </div>

  <!-- Body -->
  <div class="reg-body">

    <% if(success){ %>
    <!-- ── SUCCESS STATE ── -->
    <div class="success-box mb-4">
      <i class="bi bi-patch-check-fill text-success" style="font-size:3rem;"></i>
      <h5 class="fw-bold text-success mt-2 mb-1">✅ Registration Successful!</h5>
      <p class="text-success mb-3">Your license has been activated successfully.</p>
      <% const lic = license; %>
      <% if(lic && lic.status === 'active'){ %>
      <div class="p-2 rounded mb-3" style="background:rgba(40,167,69,0.1);">
        <div class="small"><strong>Registered to:</strong> <%= lic.registeredName %> — <%= lic.registeredCompany %></div>
        <div class="small"><strong>Valid until:</strong> <%= new Date(lic.expiryDate).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) %></div>
        <div class="small text-success fw-bold"><strong><%= lic.daysLeft %> days</strong> remaining</div>
      </div>
      <% } %>
      <a href="/" class="btn btn-success fw-bold px-5 py-2">
        <i class="bi bi-arrow-right-circle me-2"></i>Launch Application
      </a>
    </div>
    <% } else { %>

    <!-- ── REGISTRATION FORM ── -->
    <% if(license && license.status === 'active'){ %>
    <div class="alert alert-success d-flex gap-2 align-items-start mb-4">
      <i class="bi bi-check-circle-fill fs-5 text-success mt-1"></i>
      <div>
        <strong>License Active</strong> — Registered to <strong><%= license.registeredName %></strong><br>
        <span class="small">Expires: <%= new Date(license.expiryDate).toLocaleDateString('en-IN') %> (<%= license.daysLeft %> days left)</span>
      </div>
    </div>
    <% } %>

    <% if(error){ %>
    <div class="alert alert-danger d-flex gap-2 align-items-start mb-3">
      <i class="bi bi-exclamation-triangle-fill fs-5 mt-1 flex-shrink-0"></i>
      <div><strong>Activation Failed</strong><br><span class="small"><%= error %></span></div>
    </div>
    <% } %>

    <h6 class="fw-bold mb-1" style="color:#1a1a2e;">
      <% if(license && license.status === 'active'){ %>🔄 Re-enter License Key<% } else { %>🔑 Enter Your License Key<% } %>
    </h6>
    <p class="text-muted small mb-4">Contact your vendor to obtain a license key for this software.</p>

    <form method="POST" action="/register" autocomplete="off">
      <div class="mb-3">
        <label class="form-label fw-bold small text-uppercase text-muted">License Key *</label>
        <input type="text" name="license_key" class="form-control key-input"
               placeholder="BMES-YYYYMMDD-XXXX-XXXXXXXX"
               maxlength="28" required
               oninput="this.value=this.value.toUpperCase().replace(/[^A-Z0-9-]/g,'')">
        <div class="form-text">Format: BMES-YYYYMMDD-XXXX-XXXXXXXX</div>
      </div>
      <div class="mb-3">
        <label class="form-label fw-bold small text-uppercase text-muted">Your Name *</label>
        <input type="text" name="registered_name" class="form-control" placeholder="e.g. Rahul Sharma" required>
      </div>
      <div class="mb-4">
        <label class="form-label fw-bold small text-uppercase text-muted">Company Name *</label>
        <input type="text" name="registered_company" class="form-control" placeholder="e.g. Rahul Enterprises" required>
      </div>
      <button type="submit" class="btn btn-activate">
        <i class="bi bi-shield-check me-2"></i>Activate License
      </button>
    </form>

    <!-- Features list -->
    <div class="mt-4 pt-4 border-top feature-list">
      <div class="text-muted small fw-bold mb-2">INCLUDED IN YOUR LICENSE:</div>
      <div class="item"><i class="bi bi-check-circle-fill text-success"></i>Factory Floor Dashboard (15 Machines)</div>
      <div class="item"><i class="bi bi-check-circle-fill text-success"></i>Job Management & Operator Workflow</div>
      <div class="item"><i class="bi bi-check-circle-fill text-success"></i>Customer & Employee Master</div>
      <div class="item"><i class="bi bi-check-circle-fill text-success"></i>Attendance & Advance System</div>
      <div class="item"><i class="bi bi-check-circle-fill text-success"></i>Bill Register & 8 Reports</div>
      <div class="item"><i class="bi bi-check-circle-fill text-success"></i>Telegram Notifications</div>
    </div>
    <% } %>

    <div class="text-center mt-4 pt-3 border-top">
      <small class="text-muted">Need a license key? Contact your vendor.<br>
      <i class="bi bi-whatsapp text-success"></i> WhatsApp / Call for support</small>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
