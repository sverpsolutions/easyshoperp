<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>Customer Login — Barcode MES</title>
  <link rel="manifest" href="/portal/manifest.json">
  <meta name="theme-color" content="#f59e0b">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Segoe UI',system-ui,sans-serif;background:linear-gradient(160deg,#0f172a 0%,#1e293b 50%,#0f172a 100%);min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px}
    .logo-wrap{text-align:center;margin-bottom:32px}
    .logo-icon{width:80px;height:80px;background:linear-gradient(135deg,#f59e0b,#ef4444);border-radius:24px;display:flex;align-items:center;justify-content:center;font-size:2.2rem;color:white;margin:0 auto 12px;box-shadow:0 20px 40px rgba(245,158,11,0.3)}
    .logo-title{color:white;font-size:1.5rem;font-weight:700;letter-spacing:-0.5px}
    .logo-sub{color:rgba(255,255,255,0.5);font-size:0.85rem;margin-top:4px}
    .card{background:white;border-radius:24px;padding:32px 28px;width:100%;max-width:400px;box-shadow:0 30px 60px rgba(0,0,0,0.4)}
    .card h5{font-size:1.1rem;font-weight:700;color:#0f172a;margin-bottom:6px}
    .card p{color:#64748b;font-size:0.85rem;margin-bottom:24px}
    .field{margin-bottom:18px}
    .field label{display:block;font-size:0.8rem;font-weight:600;color:#475569;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px}
    .field input{width:100%;padding:14px 16px;border:2px solid #e2e8f0;border-radius:14px;font-size:1rem;outline:none;transition:.2s;background:#f8fafc;color:#0f172a}
    .field input:focus{border-color:#f59e0b;background:white;box-shadow:0 0 0 4px rgba(245,158,11,0.1)}
    .input-wrap{position:relative}
    .input-wrap .icon{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:1.1rem}
    .input-wrap input{padding-left:42px}
    .btn-login{width:100%;padding:16px;background:linear-gradient(135deg,#f59e0b,#ef4444);border:none;border-radius:14px;color:white;font-size:1rem;font-weight:700;cursor:pointer;margin-top:4px;transition:.2s;box-shadow:0 8px 24px rgba(245,158,11,0.3)}
    .btn-login:active{transform:scale(0.98)}
    .error-box{background:#fef2f2;border:1.5px solid #fecaca;border-radius:12px;padding:12px 16px;color:#dc2626;font-size:0.85rem;margin-bottom:18px;display:flex;gap:8px;align-items:center}
    .footer{color:rgba(255,255,255,0.35);font-size:0.75rem;text-align:center;margin-top:24px}
    .pwd-toggle{position:absolute;right:14px;top:50%;transform:translateY(-50%);cursor:pointer;color:#94a3b8;font-size:1.1rem;border:none;background:none;padding:0}
  </style>
</head>
<body>
  <div class="logo-wrap">
    <div class="logo-icon"><i class="bi bi-qr-code-scan"></i></div>
    <div class="logo-title">Barcode MES</div>
    <div class="logo-sub">Customer Portal</div>
  </div>

  <div class="card">
    <h5>Welcome back 👋</h5>
    <p>Sign in to track your orders and place new ones</p>

    <% if(error){ %>
    <div class="error-box"><i class="bi bi-exclamation-circle-fill"></i><span><%= error %></span></div>
    <% } %>

    <form method="POST" action="/portal/login" autocomplete="off">
      <div class="field">
        <label>Username</label>
        <div class="input-wrap">
          <i class="bi bi-person icon"></i>
          <input type="text" name="username" placeholder="Enter your username" required autocomplete="username">
        </div>
      </div>
      <div class="field">
        <label>Password</label>
        <div class="input-wrap">
          <i class="bi bi-lock icon"></i>
          <input type="password" name="password" id="pwdInput" placeholder="Enter your password" required autocomplete="current-password">
          <button type="button" class="pwd-toggle" onclick="togglePwd()"><i class="bi bi-eye" id="eyeIcon"></i></button>
        </div>
      </div>
      <button type="submit" class="btn-login"><i class="bi bi-box-arrow-in-right me-2"></i>Sign In</button>
    </form>
  </div>

  <div class="footer">Contact your vendor if you don't have login credentials<br>Barcode Label MES v4.1</div>

  <script>
    function togglePwd(){
      const i = document.getElementById('pwdInput');
      const e = document.getElementById('eyeIcon');
      if(i.type==='password'){ i.type='text'; e.className='bi bi-eye-slash'; }
      else { i.type='password'; e.className='bi bi-eye'; }
    }
    // PWA install prompt
    if('serviceWorker' in navigator){ navigator.serviceWorker.register('/portal/sw.js').catch(()=>{}); }
  </script>
</body>
</html>
