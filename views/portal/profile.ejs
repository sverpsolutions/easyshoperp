<%- include('_head') %>

<div class="topbar">
  <a href="/portal/dashboard" class="topbar-icon" style="text-decoration:none;"><i class="bi bi-arrow-left"></i></a>
  <div class="topbar-title">My Profile</div>
  <a href="/portal/logout" class="topbar-icon" style="text-decoration:none;color:white;" title="Logout"><i class="bi bi-box-arrow-right"></i></a>
</div>

<div class="page-pad">

  <% if(req.query && req.query.success){ %>
  <div style="background:#dcfce7;border:1.5px solid #86efac;border-radius:12px;padding:12px 16px;color:#15803d;font-size:0.85rem;display:flex;gap:8px;align-items:center;margin-bottom:16px;">
    <i class="bi bi-check-circle-fill"></i><span>Updated successfully!</span>
  </div>
  <% } %>
  <% if(req.query && req.query.error){ %>
  <div style="background:#fee2e2;border:1.5px solid #fca5a5;border-radius:12px;padding:12px 16px;color:#dc2626;font-size:0.85rem;display:flex;gap:8px;align-items:center;margin-bottom:16px;">
    <i class="bi bi-exclamation-triangle-fill"></i><span><%= req.query.error %></span>
  </div>
  <% } %>

  <!-- Avatar + Name -->
  <div style="text-align:center;margin-bottom:20px;">
    <div style="width:80px;height:80px;background:linear-gradient(135deg,#f59e0b,#ef4444);border-radius:24px;display:flex;align-items:center;justify-content:center;font-size:2.2rem;font-weight:700;color:white;margin:0 auto 12px;">
      <%= customer.Customer_Name.charAt(0).toUpperCase() %>
    </div>
    <div style="font-weight:800;font-size:1.1rem;color:#0f172a;"><%= customer.Customer_Name %></div>
    <div style="font-size:0.8rem;color:#64748b;margin-top:4px;">
      <span style="background:#f1f5f9;padding:3px 10px;border-radius:20px;font-weight:600;"><%= customer.Category||'Regular' %></span>
      <% if(customer.GST_No){ %> &nbsp;<span style="background:#f1f5f9;padding:3px 10px;border-radius:20px;font-size:0.75rem;">GST: <%= customer.GST_No %></span><% } %>
    </div>
  </div>

  <!-- Account Info -->
  <div class="card-m" style="margin-bottom:14px;">
    <div style="font-weight:700;font-size:0.82rem;color:#0f172a;margin-bottom:12px;"><i class="bi bi-shield-check me-2" style="color:#f59e0b;"></i>ACCOUNT INFO</div>
    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #f1f5f9;">
      <span style="font-size:0.82rem;color:#64748b;">Customer ID</span>
      <span style="font-weight:600;font-size:0.82rem;">#<%= customer.Customer_ID %></span>
    </div>
    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #f1f5f9;">
      <span style="font-size:0.82rem;color:#64748b;">Member Since</span>
      <span style="font-weight:600;font-size:0.82rem;"><%= new Date(customer.Created_Date).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) %></span>
    </div>
    <div style="display:flex;justify-content:space-between;padding:8px 0;">
      <span style="font-size:0.82rem;color:#64748b;">Credit Limit</span>
      <span style="font-weight:600;font-size:0.82rem;">₹<%= parseFloat(customer.Credit_Limit||0).toLocaleString('en-IN') %></span>
    </div>
  </div>

  <!-- Edit Contact Form -->
  <div class="card-m" style="margin-bottom:14px;">
    <div style="font-weight:700;font-size:0.82rem;color:#0f172a;margin-bottom:14px;"><i class="bi bi-person-lines-fill me-2" style="color:#3b82f6;"></i>CONTACT DETAILS</div>
    <form method="POST" action="/portal/profile">
      <div class="form-group">
        <label>Mobile *</label>
        <input type="tel" name="mobile" value="<%= customer.Mobile||'' %>" required inputmode="tel">
      </div>
      <div class="form-group">
        <label>Alt. Mobile</label>
        <input type="tel" name="alt_mobile" value="<%= customer.Alt_Mobile||'' %>" inputmode="tel">
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" value="<%= customer.Email||'' %>" placeholder="your@email.com">
      </div>
      <div class="form-group">
        <label>City</label>
        <input type="text" name="city" value="<%= customer.City||'' %>" placeholder="Your city">
      </div>
      <div class="form-group">
        <label>Address</label>
        <textarea name="address" placeholder="Full address"><%= customer.Address||'' %></textarea>
      </div>
      <button type="submit" class="btn-primary-m">
        <i class="bi bi-check2 me-2"></i>Save Changes
      </button>
    </form>
  </div>

  <!-- Change Password -->
  <div class="card-m">
    <div style="font-weight:700;font-size:0.82rem;color:#0f172a;margin-bottom:14px;"><i class="bi bi-lock me-2" style="color:#ef4444;"></i>CHANGE PASSWORD</div>
    <form method="POST" action="/portal/change-password">
      <div class="form-group">
        <label>Current Password</label>
        <input type="password" name="current_password" required placeholder="••••••••">
      </div>
      <div class="form-group">
        <label>New Password</label>
        <input type="password" name="new_password" required placeholder="Min 6 characters">
      </div>
      <div class="form-group">
        <label>Confirm New Password</label>
        <input type="password" name="confirm_password" required placeholder="Repeat new password">
      </div>
      <button type="submit" style="width:100%;padding:14px;background:#1e293b;border:none;border-radius:14px;color:white;font-size:0.95rem;font-weight:700;cursor:pointer;">
        <i class="bi bi-lock me-2"></i>Change Password
      </button>
    </form>
  </div>

  <!-- Logout -->
  <a href="/portal/logout" style="display:block;text-align:center;padding:14px;background:#fee2e2;color:#dc2626;border-radius:14px;font-weight:700;text-decoration:none;margin-top:4px;">
    <i class="bi bi-box-arrow-right me-2"></i>Logout
  </a>
</div>

<nav class="bottomnav">
  <a href="/portal/dashboard" class="nav-item"><i class="bi bi-house-fill"></i>Home</a>
  <a href="/portal/orders"    class="nav-item"><i class="bi bi-bag"></i>Orders</a>
  <a href="/portal/jobs"      class="nav-item"><i class="bi bi-gear"></i>Jobs</a>
  <a href="/portal/bills"     class="nav-item"><i class="bi bi-receipt"></i>Bills</a>
  <a href="/portal/profile"   class="nav-item active"><i class="bi bi-person"></i>Profile</a>
</nav>
</body></html>
