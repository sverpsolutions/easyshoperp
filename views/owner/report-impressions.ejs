<%- include('../partials/header') %>

<div class="container-fluid p-3">

  <!-- HEADER -->
  <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
    <a href="/owner/reports" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i>Back
    </a>
    <h5 class="mb-0 fw-bold" style="color:#1a1a2e;">
      <i class="bi bi-speedometer me-2" style="color:#f59e0b;"></i>HOURLY IMPRESSIONS REPORT
    </h5>
  </div>

  <!-- FILTERS -->
  <div class="chart-card mb-4">
    <form method="GET" class="row g-2 align-items-end">
      <div class="col-6 col-md-2">
        <label class="form-label fw-bold small">FROM DATE</label>
        <input type="date" name="from" value="<%= from %>" class="form-control form-control-sm">
      </div>
      <div class="col-6 col-md-2">
        <label class="form-label fw-bold small">TO DATE</label>
        <input type="date" name="to" value="<%= to %>" class="form-control form-control-sm">
      </div>
      <div class="col-12 col-md-3">
        <label class="form-label fw-bold small">MACHINE</label>
        <select name="machine_id" class="form-select form-select-sm">
          <option value="">— All Machines —</option>
          <% machines.forEach(m => { %>
          <option value="<%= m.Machine_ID %>" <%= machineFilter==m.Machine_ID?'selected':'' %>>
            <%= m.Machine_Name %> (<%= m.Machine_Type %>)
          </option>
          <% }) %>
        </select>
      </div>
      <div class="col-6 col-md-2">
        <button type="submit" class="btn btn-primary btn-sm w-100">
          <i class="bi bi-search me-1"></i>Filter
        </button>
      </div>
      <div class="col-6 col-md-2">
        <button type="button" class="btn btn-outline-success btn-sm w-100" onclick="exportCSV()">
          <i class="bi bi-download me-1"></i>Export CSV
        </button>
      </div>
    </form>
  </div>

  <!-- SUMMARY CARDS -->
  <% if (summary.length > 0) { %>
  <div class="row g-3 mb-4">
    <% summary.forEach(s => { %>
    <div class="col-6 col-md-3">
      <div class="stat-card running" style="border-left-color:#f59e0b;background:linear-gradient(135deg,#fff 70%,#fffbf0);">
        <div class="stat-value" style="color:#f59e0b;"><%= Number(s.Total_Impressions).toLocaleString() %></div>
        <div class="stat-label fw-bold" style="color:#1a1a2e;font-size:0.75rem;"><%= s.Machine_Name %></div>
        <div class="d-flex gap-3 mt-1" style="font-size:0.7rem;color:#6c757d;">
          <span><i class="bi bi-graph-up me-1"></i>Avg: <strong><%= Number(s.Avg_Per_Hour||0).toLocaleString() %>/hr</strong></span>
          <span><i class="bi bi-lightning me-1"></i>Peak: <strong><%= Number(s.Peak_Per_Hour||0).toLocaleString() %></strong></span>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>

  <!-- HOURLY CHART -->
  <% if (rows.length > 0) { %>
  <div class="chart-card mb-4">
    <h6 class="fw-bold mb-3" style="color:#1a1a2e;">
      <i class="bi bi-bar-chart-fill me-2" style="color:#f59e0b;"></i>Impressions by Hour
    </h6>
    <canvas id="hourlyChart" height="100"></canvas>
  </div>
  <% } %>

  <!-- TABLE -->
  <div class="chart-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h6 class="fw-bold mb-0" style="color:#1a1a2e;">
        <i class="bi bi-table me-2" style="color:#1a73e8;"></i>Impression Log
        <span class="badge bg-primary ms-2"><%= rows.length %> entries</span>
      </h6>
    </div>

    <% if (rows.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-clock-history" style="font-size:3rem;color:#adb5bd;"></i>
      <h5 class="mt-3 text-muted">No impressions logged for this period</h5>
      <p class="text-muted small">Operators log hourly impressions from their dashboard → IMPR/HR button</p>
    </div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover table-sm" id="impTable">
        <thead style="background:#f8f9fa;">
          <tr>
            <th>Date</th>
            <th>Hour</th>
            <th>Machine</th>
            <th>Type</th>
            <th>Operator</th>
            <th>Job No</th>
            <th>Customer</th>
            <th>Label</th>
            <th>Size</th>
            <th class="text-end">Impressions/Hr</th>
            <th>Remarks</th>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach(r => { %>
          <tr>
            <td class="small"><%= r.Log_Date ? new Date(r.Log_Date).toLocaleDateString('en-IN') : '—' %></td>
            <td><span class="badge bg-secondary"><%= String(r.Log_Hour).padStart(2,'0') %>:00</span></td>
            <td class="fw-bold small"><%= r.Machine_Name %></td>
            <td>
              <span class="badge <%= r.Machine_Type==='Auto'?'bg-primary':'bg-secondary' %>" style="font-size:0.65rem;">
                <%= r.Machine_Type %>
              </span>
            </td>
            <td class="small"><%= r.Operator_Name %></td>
            <td class="small text-primary"><%= r.Job_Number %></td>
            <td class="small"><%= r.Customer_Name %></td>
            <td class="small"><%= r.Label %></td>
            <td class="small"><%= r.Size %></td>
            <td class="text-end fw-bold">
              <span class="badge bg-warning text-dark fs-6" style="font-size:0.9rem!important;">
                <%= Number(r.Impressions_Count).toLocaleString() %>
              </span>
            </td>
            <td class="small text-muted"><%= r.Remarks || '—' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

<script>
<% if (rows.length > 0) { %>
// Build hourly chart — group by hour bucket
const rawData = <%- JSON.stringify(rows) %>;
const hourBuckets = {};
rawData.forEach(r => {
  const key = `${r.Machine_Name} ${String(r.Log_Hour).padStart(2,'0')}:00`;
  hourBuckets[key] = (hourBuckets[key]||0) + r.Impressions_Count;
});
const labels = Object.keys(hourBuckets).sort();
const values = labels.map(k=>hourBuckets[k]);
const colors = labels.map((_,i)=>`hsl(${40+i*15},80%,55%)`);

new Chart(document.getElementById('hourlyChart').getContext('2d'), {
  type:'bar',
  data:{ labels, datasets:[{ label:'Impressions', data:values, backgroundColor:colors, borderRadius:4 }] },
  options:{
    plugins:{ legend:{display:false} },
    scales:{
      x:{ ticks:{color:'#6c757d',maxRotation:45}, grid:{color:'#f0f0f0'} },
      y:{ ticks:{color:'#6c757d'}, grid:{color:'#f0f0f0'}, beginAtZero:true }
    }
  }
});
<% } %>

function exportCSV() {
  const rows = Array.from(document.querySelectorAll('#impTable tr'));
  const csv = rows.map(r =>
    Array.from(r.querySelectorAll('th,td')).map(c=>'"'+c.textContent.trim().replace(/"/g,'""')+'"').join(',')
  ).join('\n');
  const blob = new Blob([csv], {type:'text/csv'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'impressions_<%= from %>_to_<%= to %>.csv';
  a.click();
}
</script>

<%- include('../partials/footer') %>
