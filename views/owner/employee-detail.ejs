<%- include('../partials/header') %>
<div class="container-fluid p-3">
  <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
    <a href="/owner/employees" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0 fw-bold" style="color:#1a1a2e;"><i class="bi bi-person-badge me-2" style="color:#6f42c1;"></i><%= employee.Name %></h5>
    <span class="badge <%= employee.Role==='Owner'?'bg-dark':employee.Role==='Admin'?'bg-primary':'bg-secondary' %> fs-6"><%= employee.Role %></span>
    <% if(!employee.Is_Active){ %><span class="badge bg-danger">INACTIVE</span><% } %>
    <div class="ms-auto d-flex gap-2">
      <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#editModal"><i class="bi bi-pencil me-1"></i>Edit</button>
      <button class="btn btn-outline-warning btn-sm" data-bs-toggle="modal" data-bs-target="#pwdModal"><i class="bi bi-key me-1"></i>Reset Password</button>
    </div>
  </div>

  <div class="row g-3">
    <!-- Profile -->
    <div class="col-md-4">
      <div class="chart-card h-100">
        <h6 class="fw-bold mb-3" style="color:#6f42c1;"><i class="bi bi-person-circle me-1"></i>Profile</h6>
        <!-- Employee Photo -->
        <div class="text-center mb-3">
          <div class="position-relative d-inline-block">
            <% if(employee.Photo_Path){ %>
              <img src="<%= employee.Photo_Path %>" class="rounded-circle border border-3" style="width:90px;height:90px;object-fit:cover;border-color:#6f42c1 !important;">
            <% } else { %>
              <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:90px;height:90px;background:#e9ecef;font-size:2rem;color:#6f42c1;">
                <i class="bi bi-person-fill"></i>
              </div>
            <% } %>
          </div>
          <div class="mt-2">
            <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#photoModal">
              <i class="bi bi-camera me-1"></i>Change Photo
            </button>
          </div>
        </div>
        <div class="detail-group">
          <div class="detail-item"><span>Username</span><strong class="font-monospace"><%= employee.Username %></strong></div>
          <div class="detail-item"><span>Mobile</span><strong><%= employee.Mobile||'—' %></strong></div>
          <div class="detail-item"><span>Father's Name</span><strong><%= employee.Father_Name||'—' %></strong></div>
          <div class="detail-item"><span>Aadhar</span><strong class="font-monospace"><%= employee.Aadhar_No||'—' %></strong></div>
          <div class="detail-item"><span>Emergency</span><strong><%= employee.Emergency_Contact||'—' %></strong></div>
          <div class="detail-item"><span>Join Date</span><strong><%= employee.Join_Date?new Date(employee.Join_Date).toLocaleDateString('en-IN'):'—' %></strong></div>
          <div class="detail-item"><span>Monthly Salary</span><strong class="text-success">₹<%= parseFloat(employee.Monthly_Salary||0).toLocaleString('en-IN') %></strong></div>
        </div>
        <% if(employee.Address){ %><div class="mt-2 p-2 bg-light rounded small text-muted"><i class="bi bi-geo-alt me-1"></i><%= employee.Address %></div><% } %>
        <!-- Documents Section -->
        <div class="mt-3 p-2 rounded" style="background:#f8f9fa;border-left:3px solid #6f42c1;">
          <div class="fw-bold small mb-2"><i class="bi bi-folder2 me-1"></i>Documents</div>
          <div class="d-flex justify-content-between align-items-center mb-1">
            <small>📄 Resume</small>
            <% if(employee.Resume_Path){ %>
              <a href="<%= employee.Resume_Path %>" target="_blank" class="btn btn-xs btn-outline-primary" style="padding:1px 6px;font-size:0.7rem;"><i class="bi bi-eye"></i> View</a>
            <% } else { %>
              <button class="btn btn-xs btn-outline-secondary" style="padding:1px 6px;font-size:0.7rem;" data-bs-toggle="modal" data-bs-target="#uploadDocModal" onclick="setDocType('resume')">Upload</button>
            <% } %>
          </div>
          <div class="d-flex justify-content-between align-items-center">
            <small>🪪 Aadhar Card</small>
            <% if(employee.Aadhar_Path){ %>
              <a href="<%= employee.Aadhar_Path %>" target="_blank" class="btn btn-xs btn-outline-primary" style="padding:1px 6px;font-size:0.7rem;"><i class="bi bi-eye"></i> View</a>
            <% } else { %>
              <button class="btn btn-xs btn-outline-secondary" style="padding:1px 6px;font-size:0.7rem;" data-bs-toggle="modal" data-bs-target="#uploadDocModal" onclick="setDocType('aadhar')">Upload</button>
            <% } %>
          </div>
        </div>

        <% if(employee.Bank_Name){ %>
        <div class="mt-2 p-2 rounded small" style="background:#f0f4ff;border-left:3px solid #6f42c1;">
          <strong>Bank:</strong> <%= employee.Bank_Name %><br>
          <strong>A/C:</strong> <span class="font-monospace"><%= employee.Bank_Account||'—' %></span><br>
          <strong>IFSC:</strong> <span class="font-monospace"><%= employee.Bank_IFSC||'—' %></span>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Advance Summary -->
    <div class="col-md-8">
      <div class="row g-2 mb-3">
        <div class="col-6 col-md-3"><div class="stat-card running"><div class="stat-value">₹<%= parseFloat(advStats.This_Month||0).toLocaleString('en-IN') %></div><div class="stat-label">This Month Taken</div></div></div>
        <div class="col-6 col-md-3"><div class="stat-card pending"><div class="stat-value">₹<%= parseFloat(employee.Advance_Limit_Monthly||5000).toLocaleString('en-IN') %></div><div class="stat-label">Monthly Limit</div></div></div>
        <div class="col-6 col-md-3"><div class="stat-card stopped"><div class="stat-value">₹<%= parseFloat(advStats.Balance_To_Recover||0).toLocaleString('en-IN') %></div><div class="stat-label">Pending Recovery</div></div></div>
        <div class="col-6 col-md-3"><div class="stat-card utilization"><div class="stat-value">₹<%= parseFloat(advStats.Total_Taken||0).toLocaleString('en-IN') %></div><div class="stat-label">Total Taken Ever</div></div></div>
      </div>

      <!-- Progress bar: this month vs limit -->
      <% const pct = Math.min(100, Math.round(parseFloat(advStats.This_Month||0) / Math.max(1,parseFloat(employee.Advance_Limit_Monthly||5000)) * 100)); %>
      <div class="chart-card mb-3">
        <div class="d-flex justify-content-between align-items-center mb-1">
          <small class="fw-bold">This Month Advance Usage</small>
          <small class="fw-bold <%= pct>=100?'text-danger':pct>=75?'text-warning':'' %>"><%= pct %>% of limit</small>
        </div>
        <div class="progress" style="height:12px;">
          <div class="progress-bar <%= pct>=100?'bg-danger':pct>=75?'bg-warning':'bg-success' %>" style="width:<%= pct %>%;"></div>
        </div>
        <div class="d-flex justify-content-between mt-1">
          <small class="text-muted">₹<%= parseFloat(advStats.This_Month||0).toLocaleString('en-IN') %> used</small>
          <small class="text-muted">₹<%= (parseFloat(employee.Advance_Limit_Monthly||5000)-parseFloat(advStats.This_Month||0)).toLocaleString('en-IN') %> remaining</small>
        </div>
      </div>

      <!-- Advance History -->
      <div class="chart-card">
        <h6 class="fw-bold mb-3" style="color:#6f42c1;"><i class="bi bi-cash-stack me-1"></i>Advance History</h6>
        <div class="table-responsive" style="max-height:260px;overflow-y:auto;">
          <table class="table table-sm table-hover">
            <thead style="position:sticky;top:0;background:#f8f9fa;z-index:1;">
              <tr><th>Date</th><th>Requested</th><th>Approved</th><th>Paid</th><th>Status</th><th>Deducted</th><th>Action</th></tr>
            </thead>
            <tbody>
              <% advances.forEach(a=>{ %>
              <tr>
                <td class="small"><%= new Date(a.Request_Date).toLocaleDateString('en-IN') %></td>
                <td class="text-end">₹<%= parseFloat(a.Amount_Requested).toLocaleString('en-IN') %></td>
                <td class="text-end"><%= a.Amount_Approved?'₹'+parseFloat(a.Amount_Approved).toLocaleString('en-IN'):'—' %></td>
                <td class="text-end fw-bold <%= a.Amount_Paid?'text-danger':'' %>"><%= a.Amount_Paid?'₹'+parseFloat(a.Amount_Paid).toLocaleString('en-IN'):'—' %></td>
                <td>
                  <span class="badge bg-<%= a.Status==='Paid'?'danger':a.Status==='Approved'?'warning text-dark':a.Status==='Rejected'?'secondary':'primary' %>"><%= a.Status %></span>
                </td>
                <td class="text-center">
                  <% if(a.Status==='Paid'){ %>
                    <% if(a.Is_Deducted){ %>
                      <span class="badge bg-success"><i class="bi bi-check"></i> <%= a.Deduct_Month %></span>
                    <% } else { %>
                      <span class="badge bg-warning text-dark">Not Yet</span>
                    <% } %>
                  <% } else { %>—<% } %>
                </td>
                <td>
                  <% if(a.Status==='Paid' && !a.Is_Deducted){ %>
                  <form method="POST" action="/owner/employees/<%= employee.Employee_ID %>/advance/<%= a.Advance_ID %>/deduct" class="d-inline">
                    <input type="hidden" name="deduct_month" value="<%= new Date().toISOString().slice(0,7) %>">
                    <button class="btn btn-xs btn-outline-success" style="padding:1px 6px;font-size:0.7rem;" onclick="return confirm('Mark as deducted from salary?')">Mark Deducted</button>
                  </form>
                  <% } %>
                  <% if(a.Reason){ %><span class="ms-1 text-muted small" title="<%= a.Reason %>"><i class="bi bi-info-circle"></i></span><% } %>
                </td>
              </tr>
              <% }) %>
              <% if(!advances.length){ %><tr><td colspan="7" class="text-center text-muted py-3">No advance history</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Jobs -->
    <div class="col-12">
      <div class="chart-card">
        <h6 class="fw-bold mb-3" style="color:#6f42c1;"><i class="bi bi-list-check me-1"></i>Recent Jobs</h6>
        <div class="table-responsive">
          <table class="table table-sm table-hover">
            <thead style="background:#f8f9fa;"><tr><th>Job No</th><th>Customer</th><th>Machine</th><th>Status</th><th>Start</th><th>End</th></tr></thead>
            <tbody>
              <% jobs.forEach(j=>{ %>
              <tr>
                <td class="fw-bold text-primary"><%= j.Job_Number %></td>
                <td class="small"><%= j.Customer_Name %></td>
                <td class="small"><%= j.Machine_Name %></td>
                <td><span class="badge bg-<%= j.Status==='Completed'?'success':j.Status==='Running'?'primary':'secondary' %>"><%= j.Status %></span></td>
                <td class="small text-muted"><%= j.Start_Time?new Date(j.Start_Time).toLocaleDateString('en-IN'):'—' %></td>
                <td class="small text-muted"><%= j.End_Time?new Date(j.End_Time).toLocaleDateString('en-IN'):'—' %></td>
              </tr>
              <% }) %>
              <% if(!jobs.length){ %><tr><td colspan="6" class="text-center text-muted py-3">No jobs assigned yet</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header" style="background:#1a1a2e;"><h5 class="modal-title text-white fw-bold">Edit Employee</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
      <form method="POST" action="/owner/employees/<%= employee.Employee_ID %>/update">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-4"><label class="form-label fw-bold small">FULL NAME *</label><input type="text" name="name" class="form-control" value="<%= employee.Name %>" required></div>
            <div class="col-md-2"><label class="form-label fw-bold small">ROLE</label>
              <select name="role" class="form-select"><option <%= employee.Role==='Operator'?'selected':'' %>>Operator</option><option <%= employee.Role==='Admin'?'selected':'' %>>Admin</option><option <%= employee.Role==='Owner'?'selected':'' %>>Owner</option></select>
            </div>
            <div class="col-md-3"><label class="form-label fw-bold small">MOBILE</label><input type="text" name="mobile" class="form-control" value="<%= employee.Mobile||'' %>"></div>
            <div class="col-md-3"><label class="form-label fw-bold small">FATHER NAME</label><input type="text" name="father_name" class="form-control" value="<%= employee.Father_Name||'' %>"></div>
            <div class="col-md-6"><label class="form-label fw-bold small">ADDRESS</label><input type="text" name="address" class="form-control" value="<%= employee.Address||'' %>"></div>
            <div class="col-md-3"><label class="form-label fw-bold small">AADHAR NO</label><input type="text" name="aadhar_no" class="form-control" value="<%= employee.Aadhar_No||'' %>"></div>
            <div class="col-md-3"><label class="form-label fw-bold small">EMERGENCY</label><input type="text" name="emergency_contact" class="form-control" value="<%= employee.Emergency_Contact||'' %>"></div>
            <div class="col-md-3"><label class="form-label fw-bold small">JOIN DATE</label><input type="date" name="join_date" class="form-control" value="<%= employee.Join_Date?new Date(employee.Join_Date).toISOString().split('T')[0]:'' %>"></div>
            <div class="col-md-3"><label class="form-label fw-bold small">MONTHLY SALARY (₹)</label><input type="number" name="monthly_salary" class="form-control" value="<%= employee.Monthly_Salary||0 %>"></div>
            <div class="col-md-3"><label class="form-label fw-bold small">ADVANCE LIMIT/MONTH (₹)</label><input type="number" name="advance_limit_monthly" class="form-control" value="<%= employee.Advance_Limit_Monthly||5000 %>"></div>
            <div class="col-md-3"><label class="form-label fw-bold small">ACTIVE</label>
              <select name="is_active" class="form-select"><option value="1" <%= employee.Is_Active?'selected':'' %>>Active</option><option value="0" <%= !employee.Is_Active?'selected':'' %>>Inactive</option></select>
            </div>
            <div class="col-md-4"><label class="form-label fw-bold small">BANK NAME</label><input type="text" name="bank_name" class="form-control" value="<%= employee.Bank_Name||'' %>"></div>
            <div class="col-md-4"><label class="form-label fw-bold small">ACCOUNT NO</label><input type="text" name="bank_account" class="form-control" value="<%= employee.Bank_Account||'' %>"></div>
            <div class="col-md-4"><label class="form-label fw-bold small">IFSC</label><input type="text" name="bank_ifsc" class="form-control" value="<%= employee.Bank_IFSC||'' %>"></div>
          </div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary">Save Changes</button></div>
      </form>
    </div>
  </div>
</div>

<!-- Reset Password Modal -->
<div class="modal fade" id="pwdModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header" style="background:#ffc107;"><h5 class="modal-title fw-bold"><i class="bi bi-key me-2"></i>Reset Password</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <form method="POST" action="/owner/employees/<%= employee.Employee_ID %>/reset-password">
        <div class="modal-body">
          <label class="form-label fw-bold">New Password for <strong><%= employee.Name %></strong></label>
          <input type="text" name="new_password" class="form-control form-control-lg" placeholder="Enter new password (min 4 chars)" required minlength="4" autocomplete="off">
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-warning fw-bold">Reset Password</button></div>
      </form>
    </div>
  </div>
</div>
<!-- Photo Upload Modal -->
<div class="modal fade" id="photoModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header" style="background:#6f42c1;"><h5 class="modal-title text-white fw-bold"><i class="bi bi-camera me-2"></i>Update Photo</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
      <form method="POST" action="/owner/employees/<%= employee.Employee_ID %>/upload-photo" enctype="multipart/form-data">
        <div class="modal-body text-center">
          <div class="mb-3">
            <label class="form-label fw-bold">Choose Photo</label>
            <input type="file" name="photo" id="photoInput" class="form-control" accept="image/*" required onchange="previewPhoto(this)">
            <div class="form-text">JPG/PNG, max 2MB</div>
          </div>
          <div id="photoPreview" class="mt-2" style="display:none;">
            <img id="previewImg" class="rounded-circle border" style="width:100px;height:100px;object-fit:cover;">
          </div>
          <div class="mt-3 p-2 rounded" style="background:#f0f4ff;">
            <small class="text-muted"><i class="bi bi-camera me-1"></i>Tip: On mobile, you can take a photo directly with your camera</small>
          </div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn fw-bold" style="background:#6f42c1;color:white;"><i class="bi bi-upload me-1"></i>Upload Photo</button></div>
      </form>
    </div>
  </div>
</div>

<!-- Document Upload Modal -->
<div class="modal fade" id="uploadDocModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header" style="background:#1a1a2e;"><h5 class="modal-title text-white fw-bold"><i class="bi bi-folder-plus me-2"></i>Upload Document</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
      <form method="POST" action="/owner/employees/<%= employee.Employee_ID %>/upload-doc" enctype="multipart/form-data">
        <input type="hidden" name="doc_type" id="docTypeInput" value="resume">
        <div class="modal-body">
          <div id="docTypeLabel" class="alert alert-info mb-3">Uploading: <strong id="docTypeName">Resume</strong></div>
          <label class="form-label fw-bold">Select File</label>
          <input type="file" name="document" class="form-control" accept=".pdf,.jpg,.jpeg,.png" required>
          <div class="form-text">PDF/JPG/PNG, max 5MB</div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary fw-bold"><i class="bi bi-upload me-1"></i>Upload</button></div>
      </form>
    </div>
  </div>
</div>
<script>
function previewPhoto(input){
  if(input.files && input.files[0]){
    const r=new FileReader();
    r.onload=e=>{document.getElementById('previewImg').src=e.target.result;document.getElementById('photoPreview').style.display='block';};
    r.readAsDataURL(input.files[0]);
  }
}
function setDocType(t){
  document.getElementById('docTypeInput').value=t;
  document.getElementById('docTypeName').textContent=t==='resume'?'Resume':'Aadhar Card';
}
</script>
<%- include('../partials/footer') %>
