<%- include('../partials/header') %>
<% function fmtQty(n){ return Number(n||0).toLocaleString(); } %>

<div class="container-fluid p-3">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0" style="color:#1a1a2e;">
      <i class="bi bi-person-badge me-2" style="color:#fd7e14;"></i>OPERATOR × LABEL TYPE REPORT
    </h5>
    <a href="/owner/reports" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
  </div>

  <form class="chart-card mb-3" method="GET">
    <div class="row g-2 align-items-end">
      <div class="col-md-3"><label class="form-label fw-bold small">FROM</label><input type="date" name="from" value="<%= from %>" class="form-control"></div>
      <div class="col-md-3"><label class="form-label fw-bold small">TO</label><input type="date" name="to" value="<%= to %>" class="form-control"></div>
      <div class="col-md-2"><button type="submit" class="btn btn-primary w-100"><i class="bi bi-search me-1"></i>Filter</button></div>
    </div>
  </form>

  <%
    // Group by operator
    const grouped = {};
    rows.forEach(r => {
      if (!grouped[r.Operator_Name]) grouped[r.Operator_Name] = [];
      grouped[r.Operator_Name].push(r);
    });
  %>

  <div class="row g-3">
    <% Object.entries(grouped).forEach(([opName, opRows]) => {
       const opTotal = opRows.reduce((s,r)=>s+(r.Total_Produced||0),0); %>
    <div class="col-md-6 col-xl-4">
      <div class="chart-card h-100">
        <div class="d-flex align-items-center gap-2 mb-3">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
               style="width:40px;height:40px;background:#fd7e1420;">
            <i class="bi bi-person-fill" style="color:#fd7e14;"></i>
          </div>
          <div>
            <div class="fw-bold" style="color:#1a1a2e;"><%= opName %></div>
            <div class="text-muted small">Total: <strong><%= fmtQty(opTotal) %></strong> pcs</div>
          </div>
        </div>
        <table class="table table-sm mb-0" style="font-size:0.78rem;">
          <thead><tr style="color:#6c757d; font-size:0.68rem; text-transform:uppercase;">
            <th>Label / Size</th><th class="text-center">Jobs</th><th class="text-end">Produced</th>
          </tr></thead>
          <tbody>
            <% opRows.forEach(r => { %>
            <tr>
              <td>
                <span class="badge <%= r.Label_Type==='Printed'?'bg-primary':'bg-secondary' %> me-1" style="font-size:0.6rem;"><%= r.Label_Type %></span>
                <span style="color:#1a1a2e;"><%= r.Label_Name!=='—'?r.Label_Name:r.Size||'—' %></span>
              </td>
              <td class="text-center"><%= r.Jobs_Done %></td>
              <td class="text-end text-success fw-bold"><%= fmtQty(r.Total_Produced) %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <% }) %>
    <% if(!rows.length) { %>
    <div class="col-12"><div class="chart-card text-center py-5 text-muted">No production data for selected period</div></div>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
