<%- include('../partials/header') %>
<div class="container-fluid p-3">
  <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <h5 class="mb-0 fw-bold" style="color:#1a1a2e;"><i class="bi bi-people-fill me-2" style="color:#6f42c1;"></i>EMPLOYEE MASTER</h5>
    <div class="d-flex gap-2">
      <a href="/owner/advances" class="btn btn-warning btn-sm">
        <i class="bi bi-cash-stack me-1"></i>Advance Requests
        <% const pending = Object.values(pendingMap).reduce((s,p)=>s+p.Pending_Count,0);
           if(pending>0){ %><span class="badge bg-danger ms-1"><%= pending %></span><% } %>
      </a>
      <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addEmpModal">
        <i class="bi bi-person-plus me-1"></i>Add Employee
      </button>
    </div>
  </div>

  <!-- Stats -->
  <div class="row g-2 mb-3">
    <div class="col-6 col-md-3"><div class="stat-card running"><div class="stat-value"><%= employees.filter(e=>e.Role==='Operator').length %></div><div class="stat-label">Operators</div></div></div>
    <div class="col-6 col-md-3"><div class="stat-card idle"><div class="stat-value"><%= employees.filter(e=>e.Role==='Admin').length %></div><div class="stat-label">Admins</div></div></div>
    <div class="col-6 col-md-3"><div class="stat-card pending"><div class="stat-value">₹<%= employees.reduce((s,e)=>s+parseFloat(e.Pending_Recovery||0),0).toLocaleString('en-IN') %></div><div class="stat-label">Advance to Recover</div></div></div>
    <div class="col-6 col-md-3"><div class="stat-card utilization"><div class="stat-value">₹<%= employees.reduce((s,e)=>s+parseFloat(e.This_Month_Advance||0),0).toLocaleString('en-IN') %></div><div class="stat-label">This Month Advances</div></div></div>
  </div>

  <!-- Table -->
  <div class="chart-card">
    <div class="table-responsive">
      <table class="table table-hover table-sm mb-0">
        <thead style="background:#f8f9fa;"><tr>
          <th>#</th><th>Name</th><th>Role</th><th>Mobile</th><th>Join Date</th>
          <th class="text-end">Salary</th><th class="text-end">Advance Limit/Mo</th>
          <th class="text-end">Pending Recovery</th><th>This Month</th><th>Actions</th>
        </tr></thead>
        <tbody>
          <% employees.forEach((e,i)=>{ %>
          <tr>
            <td class="text-muted small"><%= i+1 %></td>
            <td>
              <a href="/owner/employees/<%= e.Employee_ID %>" class="fw-bold text-decoration-none"><%= e.Name %></a>
              <% if(pendingMap[e.Employee_ID]?.Pending_Count>0){ %>
                <span class="badge bg-warning text-dark ms-1"><%= pendingMap[e.Employee_ID].Pending_Count %> pending</span>
              <% } %>
            </td>
            <td><span class="badge <%= e.Role==='Owner'?'bg-dark':e.Role==='Admin'?'bg-primary':'bg-secondary' %>"><%= e.Role %></span></td>
            <td class="small"><%= e.Mobile||'—' %></td>
            <td class="small"><%= e.Join_Date?new Date(e.Join_Date).toLocaleDateString('en-IN'):'—' %></td>
            <td class="text-end small">₹<%= parseFloat(e.Monthly_Salary||0).toLocaleString('en-IN') %></td>
            <td class="text-end small">₹<%= parseFloat(e.Advance_Limit_Monthly||5000).toLocaleString('en-IN') %></td>
            <td class="text-end fw-bold <%= parseFloat(e.Pending_Recovery||0)>0?'text-danger':'' %>">
              ₹<%= parseFloat(e.Pending_Recovery||0).toLocaleString('en-IN') %>
            </td>
            <td class="text-end small">₹<%= parseFloat(e.This_Month_Advance||0).toLocaleString('en-IN') %></td>
            <td><a href="/owner/employees/<%= e.Employee_ID %>" class="btn btn-xs btn-outline-primary" style="padding:2px 8px;font-size:0.75rem;"><i class="bi bi-eye"></i></a></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add Employee Modal -->
<div class="modal fade" id="addEmpModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header" style="background:#1a1a2e;"><h5 class="modal-title text-white fw-bold"><i class="bi bi-person-plus me-2"></i>Add Employee</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
      <form method="POST" action="/owner/employees">
        <div class="modal-body">
          <div class="row g-3">
            <!-- Basic -->
            <div class="col-12"><div class="fw-bold small text-muted border-bottom pb-1 mb-1">BASIC INFO</div></div>
            <div class="col-md-4"><label class="form-label fw-bold small">FULL NAME *</label><input type="text" name="name" class="form-control" required placeholder="Full Name"></div>
            <div class="col-md-2"><label class="form-label fw-bold small">ROLE *</label>
              <select name="role" class="form-select" required>
                <option value="Operator">Operator</option><option value="Admin">Admin</option><option value="Owner">Owner</option>
              </select>
            </div>
            <div class="col-md-3"><label class="form-label fw-bold small">MOBILE</label><input type="text" name="mobile" class="form-control" placeholder="9XXXXXXXXX"></div>
            <div class="col-md-3"><label class="form-label fw-bold small">FATHER NAME</label><input type="text" name="father_name" class="form-control" placeholder="Father's Name"></div>
            <div class="col-md-6"><label class="form-label fw-bold small">ADDRESS</label><input type="text" name="address" class="form-control" placeholder="Home address"></div>
            <div class="col-md-3"><label class="form-label fw-bold small">AADHAR NO</label><input type="text" name="aadhar_no" class="form-control" placeholder="XXXX XXXX XXXX"></div>
            <div class="col-md-3"><label class="form-label fw-bold small">EMERGENCY CONTACT</label><input type="text" name="emergency_contact" class="form-control" placeholder="Mobile"></div>
            <!-- Work -->
            <div class="col-12"><div class="fw-bold small text-muted border-bottom pb-1 mb-1">WORK & SALARY</div></div>
            <div class="col-md-3"><label class="form-label fw-bold small">JOIN DATE</label><input type="date" name="join_date" class="form-control"></div>
            <div class="col-md-3"><label class="form-label fw-bold small">MONTHLY SALARY (₹)</label><input type="number" name="monthly_salary" class="form-control" placeholder="0" min="0"></div>
            <div class="col-md-3"><label class="form-label fw-bold small">ADVANCE LIMIT/MONTH (₹)</label><input type="number" name="advance_limit_monthly" class="form-control" placeholder="5000" value="5000"></div>
            <!-- Bank -->
            <div class="col-12"><div class="fw-bold small text-muted border-bottom pb-1 mb-1">BANK DETAILS (optional)</div></div>
            <div class="col-md-4"><label class="form-label fw-bold small">BANK NAME</label><input type="text" name="bank_name" class="form-control" placeholder="SBI, HDFC..."></div>
            <div class="col-md-4"><label class="form-label fw-bold small">ACCOUNT NO</label><input type="text" name="bank_account" class="form-control" placeholder="Account Number"></div>
            <div class="col-md-4"><label class="form-label fw-bold small">IFSC CODE</label><input type="text" name="bank_ifsc" class="form-control" placeholder="SBIN0001234"></div>
            <!-- Login -->
            <div class="col-12"><div class="fw-bold small text-muted border-bottom pb-1 mb-1">LOGIN CREDENTIALS</div></div>
            <div class="col-md-4"><label class="form-label fw-bold small">USERNAME *</label><input type="text" name="username" class="form-control" required placeholder="login username"></div>
            <div class="col-md-4"><label class="form-label fw-bold small">PASSWORD *</label><input type="password" name="password" class="form-control" required placeholder="min 4 chars"></div>
          </div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary fw-bold"><i class="bi bi-check-lg me-1"></i>Add Employee</button></div>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
