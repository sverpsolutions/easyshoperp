Options -Indexes
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Serve React app for root URL
RewriteRule ^$ public/react/index.html [L]

# Serve React built assets directly from public/react/assets/
RewriteRule ^assets/(.*)$ public/react/assets/$1 [L]

# Allow public assets (React build, uploads, images)
RewriteCond %{REQUEST_URI} ^/public/ [NC]
RewriteRule ^ - [L]

RewriteCond %{REQUEST_URI} ^/uploads/ [NC]
RewriteRule ^ - [L]

# React SPA — serve index.html for all non-API, non-file routes
RewriteCond %{REQUEST_URI} !^/api/ [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ public/react/index.html [L]

# CodeIgniter API routes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php/$1 [L]
