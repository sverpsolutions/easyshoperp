# ============================================
# Barcode Label MES v4.1 — Configuration
# Copy this file to .env and fill in values
# ============================================

# Database (SQL Server)
DB_SERVER=localhost
DB_NAME=BarcodeMES
DB_USER=sa
DB_PASSWORD=YourPassword@123
DB_PORT=1433

# Session
SESSION_SECRET=change-this-to-a-random-string-min-32-chars

# Server
PORT=3000

# Telegram (optional — for notifications)
TELEGRAM_BOT_TOKEN=
